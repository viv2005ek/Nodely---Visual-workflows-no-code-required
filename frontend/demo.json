                "code": "// Combine retrieved documents into a single context string\nconst docs = database-1.rows;\nlet context = '';\ndocs.forEach((doc, idx) => {\n  context += `[${idx+1}] ${doc.content}\\n\\n`;\n});\nreturn { context: context, question: userInput-1.value };"
            },
            "width": 300,
            "height": 280
        },
